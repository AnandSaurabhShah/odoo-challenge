generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/*
|--------------------------------------------------------------------------
| ENUMS
|--------------------------------------------------------------------------
*/

enum RecordStatus {
  ACTIVE
  INACTIVE
}

enum UserRole {
  ADMIN
  ASSET_MANAGER
  DEPARTMENT_HEAD
  EMPLOYEE
}

enum AssetStatus {
  AVAILABLE
  ALLOCATED
  RESERVED
  UNDER_MAINTENANCE
  LOST
  RETIRED
  DISPOSED
}

enum AssetCondition {
  NEW
  GOOD
  FAIR
  POOR
  DAMAGED
}

/*
|--------------------------------------------------------------------------
| FOUNDATION MODELS
|--------------------------------------------------------------------------
*/

model Department {
  id                 String       @id @default(uuid())
  name               String
  code               String       @unique
  description        String?
  status             RecordStatus @default(ACTIVE)

  parentDepartmentId String?
  parentDepartment   Department?  @relation("DepartmentHierarchy", fields: [parentDepartmentId], references: [id])
  childDepartments   Department[] @relation("DepartmentHierarchy")

  headId             String?      @unique
  head               User?        @relation("DepartmentHead", fields: [headId], references: [id])

  users              User[]       @relation("DepartmentUsers")
  ownedAssets        Asset[]      @relation("DepartmentAssets")
  

  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
}

model User {
  id              String       @id @default(uuid())
  employeeId      String       @unique
  fullName        String
  email           String       @unique
  password        String
  phone           String?
  designation     String?

  role            UserRole
  status          RecordStatus @default(ACTIVE)

  departmentId    String
  department       Department   @relation("DepartmentUsers", fields: [departmentId], references: [id])

  headedDepartment Department?  @relation("DepartmentHead")

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model AssetCategory {
  id            String       @id @default(uuid())
  name          String
  code          String       @unique
  description   String?

  isBookable    Boolean      @default(false)
  customFields  Json?

  status        RecordStatus @default(ACTIVE)

  assets        Asset[]      @relation("CategoryAssets")

  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model Asset {
  id                  String          @id @default(uuid())

  assetTag            String          @unique
  name                String
  description         String?

  serialNumber        String?
  qrCode              String?

  categoryId          String
  category            AssetCategory   @relation("CategoryAssets", fields: [categoryId], references: [id])

  ownerDepartmentId   String
  ownerDepartment     Department      @relation("DepartmentAssets", fields: [ownerDepartmentId], references: [id])

  locationCode        String

  status              AssetStatus     @default(AVAILABLE)
  condition           AssetCondition  @default(NEW)

  purchaseDate        DateTime?
  warrantyExpiry      DateTime?

  acquisitionCost     Decimal?        @db.Decimal(12,2)
  vendor              String?

  imageUrl            String?
  documentUrl         String?

  isBookable          Boolean         @default(false)

  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
}