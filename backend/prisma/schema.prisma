generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/**
 * |--------------------------------------------------------------------------
 * | ENUMS
 * |--------------------------------------------------------------------------
 */

enum RecordStatus {
  ACTIVE
  INACTIVE
}

enum UserRole {
  ADMIN
  ASSET_MANAGER
  DEPARTMENT_HEAD
  EMPLOYEE
}

enum AssetStatus {
  AVAILABLE
  ALLOCATED
  RESERVED
  UNDER_MAINTENANCE
  LOST
  RETIRED
  DISPOSED
}

enum AssetCondition {
  NEW
  GOOD
  FAIR
  POOR
  DAMAGED
}

enum TransferStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum BookingStatus {
  UPCOMING
  ONGOING
  COMPLETED
  CANCELLED
}

enum MaintenanceStatus {
  PENDING
  APPROVED
  ASSIGNED
  IN_PROGRESS
  RESOLVED
  REJECTED
}

enum MaintenancePriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AuditStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
}

enum AuditResult {
  PENDING
  VERIFIED
  MISSING
  DAMAGED
}

enum NotificationType {
  ASSET_ASSIGNED
  TRANSFER_APPROVED
  TRANSFER_REJECTED
  BOOKING_CONFIRMED
  BOOKING_CANCELLED
  BOOKING_REMINDER
  MAINTENANCE_APPROVED
  MAINTENANCE_REJECTED
  OVERDUE_RETURN
  AUDIT_DISCREPANCY
}

enum ActivityAction {
  CREATE
  UPDATE
  DELETE
  ALLOCATE
  RETURN
  TRANSFER
  BOOK
  CANCEL_BOOKING
  MAINTENANCE_REQUEST
  MAINTENANCE_APPROVE
  MAINTENANCE_RESOLVE
  AUDIT_CREATE
  AUDIT_VERIFY
  LOGIN
}

/**
 * |--------------------------------------------------------------------------
 * | FOUNDATION MODELS
 * |--------------------------------------------------------------------------
 */

model Department {
  id          String       @id @default(uuid())
  name        String
  code        String       @unique
  description String?
  status      RecordStatus @default(ACTIVE)

  parentDepartmentId String?
  parentDepartment   Department?  @relation("DepartmentHierarchy", fields: [parentDepartmentId], references: [id])
  childDepartments   Department[] @relation("DepartmentHierarchy")

  headId String? @unique
  head   User?   @relation("DepartmentHead", fields: [headId], references: [id])

  users       User[]       @relation("DepartmentUsers")
  ownedAssets Asset[]      @relation("DepartmentAssets")
  auditCycles AuditCycle[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
}

model User {
  id          String  @id @default(uuid())
  employeeId  String  @unique
  fullName    String
  email       String  @unique
  password    String
  phone       String?
  designation String?

  role   UserRole
  status RecordStatus @default(ACTIVE)

  departmentId String
  department   Department @relation("DepartmentUsers", fields: [departmentId], references: [id])

  headedDepartment Department? @relation("DepartmentHead")

  assetAllocations   AssetAllocation[] @relation("AllocationHolder")
  createdAllocations AssetAllocation[] @relation("AllocationCreator")

  transferFrom      TransferRequest[] @relation("TransferFromUser")
  transferTo        TransferRequest[] @relation("TransferToUser")
  transferRequested TransferRequest[] @relation("TransferRequestedBy")
  transferApproved  TransferRequest[] @relation("TransferApprovedBy")

  resourceBookings ResourceBooking[] @relation("BookingCreator")

  reportedMaintenance MaintenanceRequest[] @relation("MaintenanceReporter")
  approvedMaintenance MaintenanceRequest[] @relation("MaintenanceApprover")
  assignedMaintenance MaintenanceRequest[] @relation("MaintenanceTechnician")

  createdAuditCycles AuditCycle[]      @relation("AuditCreator")
  auditAssignments   AuditAssignment[]
  verifiedAuditItems AuditItem[]       @relation("AuditVerifier")

  notifications Notification[]
  activityLogs  ActivityLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([departmentId])
  @@index([role])
  @@index([status])
}

model AssetCategory {
  id          String  @id @default(uuid())
  name        String
  code        String  @unique
  description String?

  isBookable   Boolean @default(false)
  customFields Json?

  status RecordStatus @default(ACTIVE)

  assets Asset[] @relation("CategoryAssets")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Asset {
  id String @id @default(uuid())

  assetTag    String  @unique
  name        String
  description String?

  serialNumber String?
  qrCode       String?

  categoryId String
  category   AssetCategory @relation("CategoryAssets", fields: [categoryId], references: [id])

  ownerDepartmentId String
  ownerDepartment   Department @relation("DepartmentAssets", fields: [ownerDepartmentId], references: [id])

  locationCode String

  status    AssetStatus    @default(AVAILABLE)
  condition AssetCondition @default(NEW)

  acquisitionDate DateTime?
  warrantyExpiry  DateTime?

  acquisitionCost Decimal? @db.Decimal(12, 2)
  vendor          String?

  imageUrl    String?
  documentUrl String?

  isBookable Boolean @default(false)

  allocations         AssetAllocation[]    @relation("AssetAllocations")
  transferRequests    TransferRequest[]    @relation("AssetTransfers")
  bookings            ResourceBooking[]    @relation("AssetBookings")
  maintenanceRequests MaintenanceRequest[] @relation("AssetMaintenance")
  auditItems          AuditItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoryId])
  @@index([ownerDepartmentId])
  @@index([status])
  @@index([condition])
  @@index([locationCode])
}

model AssetAllocation {
  id String @id @default(uuid())

  assetId String
  asset   Asset  @relation("AssetAllocations", fields: [assetId], references: [id])

  userId String
  user   User   @relation("AllocationHolder", fields: [userId], references: [id])

  allocatedById String
  allocatedBy   User   @relation("AllocationCreator", fields: [allocatedById], references: [id])

  allocatedAt        DateTime  @default(now())
  expectedReturnDate DateTime?

  returnedAt DateTime?

  returnCondition AssetCondition?
  returnRemarks   String?

  createdAt DateTime @default(now())

  @@index([assetId])
  @@index([userId])
  @@index([returnedAt])
}

model TransferRequest {
  id String @id @default(uuid())

  assetId String
  asset   Asset  @relation("AssetTransfers", fields: [assetId], references: [id])

  fromUserId String
  fromUser   User   @relation("TransferFromUser", fields: [fromUserId], references: [id])

  toUserId String
  toUser   User   @relation("TransferToUser", fields: [toUserId], references: [id])

  requestedById String
  requestedBy   User   @relation("TransferRequestedBy", fields: [requestedById], references: [id])

  approvedById String?
  approvedBy   User?   @relation("TransferApprovedBy", fields: [approvedById], references: [id])

  reason String

  status TransferStatus @default(PENDING)

  requestDate  DateTime  @default(now())
  decisionDate DateTime?

  remarks String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([assetId])
  @@index([status])
}

model ResourceBooking {
  id String @id @default(uuid())

  assetId String
  asset   Asset  @relation("AssetBookings", fields: [assetId], references: [id])

  bookedById String
  bookedBy   User   @relation("BookingCreator", fields: [bookedById], references: [id])

  startTime DateTime
  endTime   DateTime

  purpose String

  status BookingStatus @default(UPCOMING)

  cancellationReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([assetId])
  @@index([bookedById])
  @@index([status])
  @@index([assetId, status])
}

model MaintenanceRequest {
  id String @id @default(uuid())

  assetId String
  asset   Asset  @relation("AssetMaintenance", fields: [assetId], references: [id])

  reportedById String
  reportedBy   User   @relation("MaintenanceReporter", fields: [reportedById], references: [id])

  approvedById String?
  approvedBy   User?   @relation("MaintenanceApprover", fields: [approvedById], references: [id])

  assignedToId String?
  assignedTo   User?   @relation("MaintenanceTechnician", fields: [assignedToId], references: [id])

  title       String
  description String

  priority MaintenancePriority

  status MaintenanceStatus @default(PENDING)

  beforePhotoUrl String?
  afterPhotoUrl  String?

  resolutionNotes String?

  reportedAt  DateTime  @default(now())
  completedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([assetId])
  @@index([status])
}

model AuditCycle {
  id String @id @default(uuid())

  title       String
  description String?

  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])

  locationCode String?

  startDate DateTime
  endDate   DateTime

  status AuditStatus @default(PLANNED)

  createdById String
  createdBy   User   @relation("AuditCreator", fields: [createdById], references: [id])

  assignments AuditAssignment[]
  auditItems  AuditItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([departmentId])
  @@index([status])
}

model AuditAssignment {
  id String @id @default(uuid())

  auditCycleId String
  auditCycle   AuditCycle @relation(fields: [auditCycleId], references: [id])

  userId String
  user   User   @relation(fields: [userId], references: [id])

  assignedAt DateTime @default(now())

  @@unique([auditCycleId, userId])
}

model AuditItem {
  id String @id @default(uuid())

  auditCycleId String
  auditCycle   AuditCycle @relation(fields: [auditCycleId], references: [id])

  assetId String
  asset   Asset  @relation(fields: [assetId], references: [id])

  status AuditResult @default(PENDING)

  remarks String?

  verifiedById String?
  verifiedBy   User?   @relation("AuditVerifier", fields: [verifiedById], references: [id])

  verifiedAt DateTime?

  createdAt DateTime @default(now())

  @@unique([auditCycleId, assetId])
  @@index([assetId])
  @@index([status])
}

model Notification {
  id String @id @default(uuid())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  type NotificationType

  title   String
  message String

  isRead Boolean @default(false)

  relatedEntityType String?
  relatedEntityId   String?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}

model ActivityLog {
  id String @id @default(uuid())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  action ActivityAction

  entityType String
  entityId   String

  description String?

  ipAddress String?
  userAgent String?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([entityType])
  @@index([entityId])
  @@index([createdAt])
}
